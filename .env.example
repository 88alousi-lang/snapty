# ── Database ──────────────────────────────────────────────────────────────────
# Aiven (free): mysql://user:pass@host:port/dbname?ssl-mode=REQUIRED
# PlanetScale:  mysql://user:pass@host/dbname?ssl={"rejectUnauthorized":true}
DATABASE_URL=mysql://user:password@host:3306/snapty

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-string-minimum-32-chars
OAUTH_SERVER_URL=https://your-manus-oauth-url
VITE_APP_ID=your-manus-app-id
OWNER_OPEN_ID=your-open-id

# ── Encryption (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))") ──
ENCRYPTION_KEY=64-hex-chars-here

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxx

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=production
APP_URL=https://your-app.onrender.com
ALLOWED_ORIGINS=https://your-app.onrender.com

# ── AWS S3 ────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=xxxx
AWS_SECRET_ACCESS_KEY=xxxx
AWS_S3_REGION=us-east-1
AWS_S3_BUCKET_NAME=snapty-storage
